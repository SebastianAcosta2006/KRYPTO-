-- Visualizacion ASCII

traer grafica
traer nucleo

{- Datos para histograma -}
fijar datos <- [[1.2], [2.4], [1.8], [3.5], [2.1], [3.9], [2.7], [1.5], [3.1], [2.8]]

grafica::histograma(datos)

{- Datos para dispersion: y = 2x + ruido -}
fijar X <- [[1], [2], [3], [4], [5], [6], [7], [8]]
fijar Y <- [[2.1], [4.3], [5.8], [8.1], [10.2], [12.0], [14.1], [16.3]]

grafica::dispersion(X, Y)
