-- Operaciones con tableros (matrices)

traer algebra

fijar A <- [[1, 2], [3, 4]]
fijar B <- [[5, 6], [7, 8]]

algebra::mostrar(A [+] B)
algebra::mostrar(A [-] B)
algebra::mostrar(A [*] B)
algebra::mostrar(algebra::transponer(A))
algebra::mostrar(algebra::invertir(A))

fijar C <- [[2, 1, 0], [1, 3, 1], [0, 1, 2]]
algebra::mostrar(algebra::transponer(C))
algebra::mostrar(algebra::invertir(C))
